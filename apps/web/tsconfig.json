{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@munchkin/shared": ["../../packages/shared/src/index.ts"],
      "@munchkin/shared/*": ["../../packages/shared/src/*"]
    },
    "noEmit": true
  },
  "include": ["src", "vite.config.ts"]
}
